# Argus V2 — secrets file (sibling of argus.yaml)
#
# Copy this to `argus.env` and fill in. Argus loads it at startup and
# exports each KEY=value into os.environ if the variable isn't already set.
# argus.env is gitignored — never commit secrets.
#
# Lines are KEY=value, optionally `export KEY=value`. Surrounding quotes
# are stripped. No variable expansion / multiline.

# ── m01 — passive subdomain enumeration ──────────────────────
# chaos (projectdiscovery) — https://chaos.projectdiscovery.io
PDCP_API_KEY=

# ── m10 — OSINT ──────────────────────────────────────────────
# GitHub PAT (repo + read:org scopes) for trufflehog org scanning
GITHUB_TOKEN=

# Have I Been Pwned (paid API key, $4/mo)
HIBP_API_KEY=

# ── m15 — CVE intelligence feeds ─────────────────────────────
# NVD API 2.0 key. Free, instant signup at:
#   https://nvd.nist.gov/developers/request-an-api-key
# Without : 5 requests / 30s (full year pull ~4 min)
# With key: 50 requests / 30s (full year pull ~30s, 10× faster)
NVD_API_KEY=

# ── m16 — Surface intel (Shodan / Censys, used by B5+) ───────
# Shodan API key — already provisioned by CSIRT, paste here.
SHODAN_API_KEY=
# Censys API ID + secret pair — request free Researcher tier at:
#   https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── Dashboard ────────────────────────────────────────────────
# Cookie Secure: opt-out for plain HTTP local dev only.
# DASHBOARD_HTTP_DEV=1
