# ============================================================
#  h4wk3y3 container — environment
#  Copy: cp .env.example .env   (build.sh does this + generates a password)
# ============================================================

# Timezone (log timestamps + Postgres now())
TZ=Europe/Paris

# Dashboard host bind + port (container internal stays 8000).
#   H4_BIND=127.0.0.1 → loopback only; Caddy fronts the public side (TLS on 443).
#   H4_BIND=0.0.0.0   → also expose raw HTTP on the public IP (not recommended).
H4_BIND=127.0.0.1
H4_DASHBOARD_PORT=8000

# Public TLS hostname served by Caddy (port 443). Use nip.io to get a real
# Let's Encrypt cert for a bare IP without owning a domain:
#   H4_SITE_ADDRESS=<your-public-ip>.nip.io     e.g. 203.0.113.10.nip.io
# Or set your own domain (point an A record at this host first).
H4_SITE_ADDRESS=

# Container memory limit (8g comfortable; raise to 14g on a 16 GB box).
H4_MEM_LIMIT=8g

# ── Postgres backend ─────────────────────────────────────────
# Injected into the app as ARGUS_DB_URL (resolved by core/db_engine.py
# + alembic/env.py). CHANGE THE PASSWORD before exposing anything.
POSTGRES_USER=h4wk3y3
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=h4wk3y3

# Point at an EXTERNAL Postgres instead of the bundled service by setting
# ARGUS_DB_URL here (then remove the postgres service + depends_on).
# ARGUS_DB_URL=postgresql+psycopg://user:pw@external-host:5432/h4wk3y3

# ── API keys (optional — pipeline degrades gracefully without) ─
# Chaos / projectdiscovery (m02 passive source)
PDCP_API_KEY=
# GitHub token (subfinder github source + m01 secret hunt)
GH_TOKEN=
GITHUB_TOKEN=
# HIBP breach correlation (m01)
HIBP_API_KEY=

# ── Notifications (optional, see config/h4wk3y3.yaml) ────────
DISCORD_WEBHOOK=
SLACK_WEBHOOK=
