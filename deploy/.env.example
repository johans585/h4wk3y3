# ============================================================
#  Argus container — env vars
#  Copy: cp .env.example .env && edit .env
# ============================================================

# Timezone (affects log timestamps + Postgres "now()" rendering)
TZ=Europe/Paris

# Host port for the dashboard (container internal stays 8000)
ARGUS_DASHBOARD_PORT=8000

# ── Postgres backend ─────────────────────────────────────────
# Used by the `postgres` service AND injected into the `argus` service
# as ARGUS_DB_URL (resolved by core/db_engine.py + alembic/env.py).
# Override these to harden the deployment (don't ship the default
# password to anything reachable from the internet).
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus_local_dev
POSTGRES_DB=argus_main

# Override ARGUS_DB_URL only if you want to point Argus at an EXTERNAL
# Postgres instead of the bundled `postgres` service (e.g. RDS, managed
# Cloud SQL). When unset, docker-compose builds the URL from the
# POSTGRES_* vars above.
# ARGUS_DB_URL=postgresql+psycopg://user:pw@external-host:5432/argus

# ── API keys ─────────────────────────────────────────────────
# projectdiscovery / Chaos — m01 passive source
# Get yours at https://chaos.projectdiscovery.io
PDCP_API_KEY=

# Optional: GitHub token for subfinder (github source)
GH_TOKEN=

# ── Notifications (optional, see config/argus.yaml) ─────────
DISCORD_WEBHOOK=
SLACK_WEBHOOK=
